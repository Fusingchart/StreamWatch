rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /sightings/{userId}/{allPaths=**} {
      // Only the owner can upload to their own folder, and only a
      // reasonably-sized image (guards against storage abuse / non-photo uploads)
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // Anyone signed in can read photos (for the map view)
      allow read: if request.auth != null;
    }
  }
}
