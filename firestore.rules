rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sightings/{id} {
      // Anyone signed in (including anonymous) can read non-hidden sightings
      allow read: if request.auth != null && resource.data.hidden == false;
      // Only the owner can create their own sighting
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // No client-side updates or deletes
      allow update, delete: if false;
    }
  }
}
